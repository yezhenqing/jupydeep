        "deep_skills": {
          "type": "array",
          "title": "Skills",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "pydantic-agent/v0.3.19/refactor",
              "pydantic-agent/v0.3.19/code-review",
