              "pydantic-agent/v0.3.19/build-and-compile",
              "pydantic-agent/v0.3.19/git-workflow",
              "pydantic-agent/v0.3.19/skill-creator",
              "pydantic-agent/v0.3.19/environment-discovery",
              "pydantic-agent/v0.3.19/systematic-debugging",
              "pydantic-agent/v0.3.19/verification-strategy",
              "pydantic-agent/v0.3.19/performant-code",
              "pydantic-agent/v0.3.19/data-formats"
            ]
          },
          "default": []
