{
  "title": "jupydeep.agent",
  "description": "Configurable agents from server",
  "type": "object",
  "jupyter.lab.transform": true,
  "properties": {
    "agents": {
      "type": "object",
      "title": "Available Agents",
      "properties": {}
    },
    "additionalProperties": false
  },
  "definitions": {
    "AgentConfig": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "title": "Description"
        },
        "model": {
          "type": "string",
          "title": "The Language model of this agent",
          "default": ""
        },
        "deep_mcps": {
          "type": "array",
          "title": "MCP servers",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": []
          },
          "default": []
        },
        "capabilities": {
          "type": "array",
          "title": "Capabilities and Toolsets",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "include_todo",
              "include_filesystem",
              "include_subagents",
              "include_plan",
              "include_liteparse",
              "context_manager",
              "web_search",
              "web_fetch",
              "cost_tracking",
              "include_checkpoints",
              "include_teams",
              "include_memory"
